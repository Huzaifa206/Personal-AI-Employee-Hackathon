# Environment Variables for AI Employee
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# ===========================================
# Gmail Watcher Configuration
# ===========================================
# Path to Gmail credentials.json (downloaded from Google Cloud Console)
# Get it from: https://console.cloud.google.com/apis/credentials
GMAIL_CREDENTIALS_PATH=./credentials.json

# Gmail check interval in seconds (default: 120)
GMAIL_CHECK_INTERVAL=120

# ===========================================
# Filesystem Watcher Configuration
# ===========================================
# Path to drop folder (default: vault/Drop_Folder)
DROP_FOLDER_PATH=./Drop_Folder

# Filesystem check interval in seconds (default: 5)
FILESYSTEM_CHECK_INTERVAL=5

# ===========================================
# Vault Configuration
# ===========================================
# Path to your Obsidian vault
VAULT_PATH=./AI_Employee_Vault

# ===========================================
# Security Settings
# ===========================================
# Enable dry run mode (prevents actual actions during development)
DRY_RUN=true

# Maximum actions per hour (rate limiting)
MAX_ACTIONS_PER_HOUR=10

# ===========================================
# Logging Configuration
# ===========================================
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Log file path (default: vault/Logs/)
LOG_PATH=./logs
